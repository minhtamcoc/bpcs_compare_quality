# goals.config
#
# DOC: Task 1 embeds data with normal BPCS and writes the fixed-threshold report.
cw1 = is_true : _basic_report
# DOC: Task 2 embeds data with Adaptive BPCS and writes the dynamic-threshold report.
cw2 = is_true : _adaptive_report
# DOC: Task 3 extracts the secret from the normal BPCS stego video.
cw3 = is_true : _basic_decoded
# DOC: Task 4 extracts the secret from the Adaptive BPCS stego video.
cw4 = is_true : _adaptive_decoded
# DOC: Task 5 compares the two methods with MSE, PSNR, and changed pixels.
cw5 = is_true : _comparison_report
